# SQLite config
DB_FILE=data/scanner.db
DB_TIMEOUT_SECONDS=30
DB_BUSY_TIMEOUT_MS=5000

# MalwareBazaar API key
MB_AUTH_KEY=your_malwarebazaar_api_key_here

# YARA Rules
YARA_RULES_PATH=rules/index.yar

# Hashing
HASH_CHUNK_SIZE=4096

# Scanner / Anti-Evasion
MAX_FILE_READ_BYTES=52428800
MIN_VARIANT_BYTES=32
MAX_VARIANT_BYTES=5242880
SAMPLE_SIZE=32768

# Concurrency
THREAD_POOL_WORKERS=4
