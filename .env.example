# PostgreSQL config
DB_HOST=your_host_here
DB_PORT=your_port_here
DB_NAME=your_database_name_here
DB_USER=your_username_here
DB_PASSWORD=your_password_here

# Connection Pool
DB_POOL_MIN=10
DB_POOL_MAX=50

# MalwareBazaar API key
MB_AUTH_KEY=your_malwarebazaar_api_key_here

# YARA Rules
YARA_RULES_PATH=rules/index.yar

# Hashing
HASH_CHUNK_SIZE=4096

# Scanner / Anti-Evasion
MAX_FILE_READ_BYTES=52428800
MIN_VARIANT_BYTES=32
MAX_VARIANT_BYTES=5242880
SAMPLE_SIZE=32768

# Concurrency
THREAD_POOL_WORKERS=4
